# Function to list the members of a group.
# Replicates the absolute basic functionality of a real 'members' command
if ! findcommand members &>/dev/null; then
  if [[ "${SYSTEM_TYPE}" == "macOS" ]]; then
    function members { dscacheutil -q group -a name "${1:?No Group Supplied}" | grep users | cut -d ":" -f2- | sed 's/ //'; }
  else
    function members { [[ "$(getent group "${1?No Group Supplied}" | cut -d ":" -f4-)" ]] && getent group "${1}" | cut -d ":" -f4-; }
  fi
fi
