# tail with search highlight
# usage: tailsearch filename [search string]
function tailsearch {
  if [[ $# -eq 0 ]]; then
    echo "Usage: tailsearch filename [search string]"
    return 1
  else
    if [[ ${2} ]]; then
      tail -n 50 ${1} | perl -pe "s/${2}/${DULL_RED}$&${NORMAL}/g"
    else
      tail -n 50 ${1}
    fi
  fi
}
