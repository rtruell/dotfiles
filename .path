#!/usr/bin/env bash

# add directories of my programs, if they exist, to the beginning of PATH so they get used first.
if [ -d /usr/local/sbin ] ; then
  addpath -f /usr/local/sbin
fi

if [ -d /usr/sbin ] ; then
  addpath -f /usr/sbin
fi

if [ -d ${HOME}/sbin ] ; then
  addpath -f ${HOME}/sbin
fi

if [ -d ${HOME}/bin ] ; then
  addpath -f ${HOME}/bin
fi

# many of the utils Apple supplies in macOS are out-dated and less capable than
# the same-named GNU versions, so I want to use the GNU core and find utils and
# GNU sed instead, if they're available...so the paths to those utils get added
# to the beginning of PATH
if [ -d /usr/local/opt/gnu-sed ] ; then
  addpath -f /usr/local/opt/gnu-sed/libexec/gnubin
fi

if [ -d /usr/local/opt/findutils ] ; then
  addpath -f /usr/local/opt/findutils/libexec/gnubin
fi

if [ -d /usr/local/opt/coreutils ] ; then
  addpath -f /usr/local/opt/coreutils/libexec/gnubin
fi
