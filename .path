#!/usr/bin/env bash

# add directories of my programs, if they exist, to the beginning of PATH so
# they get used first.
if [ -d /usr/local/sbin ] ; then
  addpath -f /usr/local/sbin
fi

if [ -d /usr/sbin ] ; then
  addpath -f /usr/sbin
fi

if [ -d ${HOME}/sbin ] ; then
  addpath -f ${HOME}/sbin
fi

if [ -d ${HOME}/bin ] ; then
  addpath -f ${HOME}/bin
fi

# add the Homebrew install directories to PATH.  this only needs to be done on
# Linux because on macOS, Homebrew is installed in a directory already in PATH
if [[ "$(uname)" == "Linux" ]]; then
  hbpathname=$(dirname `locate -ir ".*brew/sbin$"`)
  if [ -d "${hbpathname}/sbin" ] ; then
    addpath -f "${hbpathname}/sbin"
  fi
  if [ -d "${hbpathname}/bin" ] ; then
    addpath -f "${hbpathname}/bin"
  fi
fi

# many of the utils Apple supplies in macOS are out-dated and less capable than
# the same-named GNU versions.  I want to use the GNU versions instead, so if
# they've been installed, the paths to them get added to the beginning of PATH
if [[ "$(uname)" == "Darwin" ]]; then
  brewprefix=`brew --prefix`
  if [ -d "${brewprefix}"/opt/gnu-sed ] ; then
    addpath -f "${brewprefix}"/opt/gnu-sed/libexec/gnubin
  fi

  if [ -d "${brewprefix}"/opt/findutils ] ; then
    addpath -f "${brewprefix}"/opt/findutils/libexec/gnubin
  fi

  if [ -d "${brewprefix}"/opt/coreutils ] ; then
    addpath -f "${brewprefix}"/opt/coreutils/libexec/gnubin
  fi

  if [ -d "${brewprefix}"/opt/curl/bin ] ; then
    addpath -f "${brewprefix}"/opt/curl/bin
  fi
fi
