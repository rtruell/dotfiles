#!/usr/bin/env bash

# add directories of my programs, if they exist, to the beginning of PATH so
# they get used first.
if [ -d /usr/local/sbin ] ; then
  addpath -f /usr/local/sbin
fi

if [ -d /usr/sbin ] ; then
  addpath -f /usr/sbin
fi

if [ -d ${HOME}/sbin ] ; then
  addpath -f ${HOME}/sbin
fi

if [ -d ${HOME}/bin ] ; then
  addpath -f ${HOME}/bin
fi

# add the Homebrew install directories to the PATH.  this needs to be done on
# Linux.  on macOS it's redundant, but the 'addpath' function makes sure that
# only one copy of each directory is in the PATH
if [ -d `brew --prefix`/sbin ] ; then
  addpath -f `brew --prefix`/sbin
fi

if [ -d `brew --prefix`/bin ] ; then
  addpath -f `brew --prefix`/bin
fi

# many of the utils Apple supplies in macOS are out-dated and less capable than
# the same-named GNU versions, so I want to use the GNU versions instead, if
# they're available...so the paths to those utils get added to the beginning of
# PATH
if [ -d `brew --prefix`/opt/gnu-sed ] ; then
  addpath -f `brew --prefix`/opt/gnu-sed/libexec/gnubin
fi

if [ -d `brew --prefix`/opt/findutils ] ; then
  addpath -f `brew --prefix`/opt/findutils/libexec/gnubin
fi

if [ -d `brew --prefix`/opt/coreutils ] ; then
  addpath -f `brew --prefix`/opt/coreutils/libexec/gnubin
fi

if [ -d `brew --prefix`/opt/curl/bin ] ; then
  addpath -f `brew --prefix`/opt/curl/bin
fi
