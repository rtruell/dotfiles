#!/usr/bin/env bash

# a - short name for the 'apt' command

# this started off as a bunch of aliases for apt, but after creating a similar
# script file for 'brew', decided to do the same for 'apt' and do away with the
# aliases.
declare -a usage=(
  " "
  "a: short name for the 'apt' command.  Also uses short names for the more"
  "   common 'apt' subcommands."
  " "
  "Usage: a [option] subcommand [argument(s)]"
  " "
  "Option:"
  "    -h: print this help message."
  " "
  "Short subcommands:"
  "     c: cleanup - does a 'sudo apt autoclean'.  Other options can be"
  "        specified and are passed through to the 'apt' command."
  "     d: dump - does an 'apt list --installed >"${HOME}"/newapt', which"
  "        writes all installed packages into the file '"${HOME}"/newapt'."
  "     h: home - opens the home page for a package, if supplied, in the default"
  "        web browser.  A package must be specified."
  "     i: info - does an 'apt show'.  A package must be specified.  Additional"
  "        options can be specified and are passed through to the 'apt' command."
  "    in: install - does a 'sudo apt install -V'.  A package must be specified."
  "        Additional options can be specified and are passed through to the"
  "        'apt' command."
  "     p: purge - does a 'sudo apt remove --purge', which completely uninstalls"
  "        a package, including its config files.  A package must be specified."
  "     r: remove - does a 'sudo apt remove', which uninstalls a package but"
  "        keeps its config files.  A package must be specified."
  "     s: search - does an 'apt search'.  Text or a regex must be specified."
  "        Additional options can be specified and are passed through to the"
  "        'apt' command."
  "    ud: update - does a 'sudo apt update'.  Additional options can be"
  "        specified and are passed through to the 'apt' command."
  "    ug: upgrade - does a 'sudo apt upgrade'.  Additional options can be"
  "        specified and are passed through to the 'apt' command."
  " "
  "Custom subcommands:"
  "    ub: up both - does a 'sudo apt update' and then a 'sudo apt upgrade'."
  "    uf: up full - does a 'sudo apt update', a 'sudo apt upgrade' and finally"
  "        a 'sudo apt autoclean'"
  " "
  "Any other subcommand is passed through to the 'apt' command unchanged."
  " "
)
function nopackage { printf '%s\n' "Must supply a package name."; exit 1; }

[[ -z "${1}" ]] && { printf '%s\n' "Must supply an option or a subcommand."; exit 1; }
command="${1}"
if [[ "${command:0:1}" == "-" ]]; then
  if [[ "${command}" == "-h" ]]; then
    printf '%s\n' "${usage[@]}"
    exit
  else
    printf '%s\n' "Invalid option." "${usage[@]}"
    exit 1
  fi
fi
case "${command}" in
   c) shift; sudo apt autoclean "$@";;
   d) apt list --installed >"${HOME}"/newapt 2>/dev/null;;
   h) shift
      if [[ -z "${1}" ]]; then nopackage; fi
      webpage=`apt show "${1}" 2>/dev/null | grep -i "^homepage" | cut -d " " -f 2`
      if [[ -z "${webpage}" ]]; then printf '%s\n' "Sorry, no homepage supplied for ${1}"; exit 1; fi
      printf '%s\n' "Opening ${webpage}."
      open "${webpage}"
      ;;
   i) shift
      if [[ -z "${1}" ]]; then nopackage; fi
      apt show "$@"
      ;;
  in) shift
      if [[ -z "${1}" ]]; then nopackage; fi
      sudo apt install -V "$@"
      ;;
   p) shift
      if [[ -z "${1}" ]]; then nopackage; fi
      sudo apt remove --purge "${1}"
      ;;
   r) shift
      if [[ -z "${1}" ]]; then nopackage; fi
      sudo apt remove "${1}"
      ;;
   s) shift
      if [[ -z "${1}" ]]; then printf '%s\n' "Must supply text or a regex."; exit 1; fi
      apt search "$@"
      ;;
  ub) sudo apt update && sudo apt upgrade;;
  ud) shift; sudo apt update "$@";;
  uf) sudo apt update && sudo apt upgrade && sudo apt autoclean;;
  ug) shift; sudo apt upgrade "$@";;
   *) apt "$@";;
esac
